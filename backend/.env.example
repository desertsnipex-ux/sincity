# Server Configuration
PORT=4173

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=sincity

# Session Secret
SESSION_SECRET=your-secret-key-here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4173/auth/google/callback

# Discord OAuth Configuration
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_CALLBACK_URL=http://localhost:4173/auth/discord/callback

# Admin Configuration
SINCITY_ADMIN_KEY=your-admin-key
SINCITY_REQUIRE_ADMIN_KEY=false
SINCITY_DISCORD_WEBHOOK=your-discord-webhook-url

# Email Configuration (for Forgot Password & Email Verification)
# Option 1: SendGrid (Recommended for production)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=desertsnipex@gmail.com

# Option 2: Gmail (For development/testing)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
